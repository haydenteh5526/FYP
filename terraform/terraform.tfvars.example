aws_region      = "eu-west-1"
project_name    = "docvault"
db_password     = "CHANGE_ME_secure_password_123"
container_image = "YOUR_AWS_ACCOUNT_ID.dkr.ecr.eu-west-1.amazonaws.com/docvault-api:latest"

# Application config (stored in AWS Secrets Manager). All optional, but for a
# working deployment set at least jwt_secret and gemini_api_key.
jwt_secret       = "CHANGE_ME_long_random_secret"
gemini_api_key   = "" # Q&A + embeddings (Ollama isn't deployed on AWS)
groq_api_key     = "" # optional alternative Q&A provider
mistral_api_key  = "" # categorisation + Mistral OCR
resend_api_key   = "" # transactional email (verification / reset)
frontend_url     = "" # e.g. https://app.example.com
# google_client_id     = ""
# google_client_secret = ""
